{
    "name": "frozonfreak/graftai",
    "description": "AI-driven, self-evolving automation engine for multi-tenant Laravel SaaS platforms",
    "type": "laravel-module",
    "license": "MIT",
    "keywords": [
        "laravel",
        "ai",
        "automation",
        "multi-tenant",
        "dsl",
        "evolution",
        "governance",
        "anthropic"
    ],
    "authors": [
        {
            "name": "laravel-graft contributors",
            "homepage": "https://github.com/frozonfreak/laravel-graft/graphs/contributors"
        }
    ],
    "require": {
        "php": "^8.3"
    },
    "extra": {
        "laravel": {
            "providers": [],
            "aliases": {}
        }
    },
    "autoload": {
        "psr-4": {
            "Modules\\GraftAI\\": "app/",
            "Modules\\GraftAI\\Database\\Factories\\": "database/factories/",
            "Modules\\GraftAI\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Modules\\GraftAI\\Tests\\": "tests/"
        }
    }
}
