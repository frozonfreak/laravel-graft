{
    "name": "frozonfreak/graftai",
    "description": "AI-driven, self-evolving automation engine for multi-tenant Laravel SaaS platforms",
    "version": "1.0.0",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "ai",
        "automation",
        "multi-tenant",
        "dsl",
        "evolution",
        "governance",
        "anthropic",
        "pipeline"
    ],
    "authors": [
        {
            "name": "laravel-graft contributors",
            "homepage": "https://github.com/frozonfreak/laravel-graft/graphs/contributors"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/support": "^13.0",
        "illuminate/database": "^13.0",
        "illuminate/http": "^13.0",
        "illuminate/routing": "^13.0",
        "illuminate/queue": "^13.0",
        "illuminate/console": "^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "GraftAI\\Providers\\GraftAIServiceProvider"
            ]
        }
    },
    "autoload": {
        "psr-4": {
            "GraftAI\\": "src/",
            "GraftAI\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "GraftAI\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
